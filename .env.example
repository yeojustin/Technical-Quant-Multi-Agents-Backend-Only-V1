# Setup configurations for the institutional quant technical analysis agent

# Choose provider: 1 for Vertex AI, 0 for Gemini Developer API (default)
GOOGLE_GENAI_USE_VERTEXAI=0

# --- Option A: Gemini Developer API (default) ---
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# --- Option B: Vertex AI (GCP) ---
# If GOOGLE_GENAI_USE_VERTEXAI is set to 1, configure the following:
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1
